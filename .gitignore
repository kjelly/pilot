# Build artifacts
/pilot
dist/
*.exe

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Data (local user state)
*.db
*.db-shm
*.db-wal
.crush/
.claude/

# Test artifacts
*.test
*.out
coverage.txt

# Editor
.idea/
.vscode/
*.swp
.DS_Store

# Verification reports (generated by scripts/pb-iter.sh)
/.verification/
*.ndjson

# Ansible local state
.ansible/
*.vault
*vault-password*

# `pilot spec --generate` output — derived, not source
/playbooks/generated/
/playbooks/*/generated/

# Stale test artifact
*.tmp

# Local-only pilot artifacts
.verification/
.playbooks/generated/
inventory*.yaml

# DNS zone data is infra topology for a PUBLIC repo — real data lives OUTSIDE
# the repo tree (in group_vars/ next to an out-of-git inventory). If anyone
# ever creates group_vars/dns/ in-repo, ignore every zone file EXCEPT the
# committed schema example. See docs/runbooks/core-infra-provider-dns-zones.md
/group_vars/dns/*.yaml
!/group_vars/dns/zones.example.yaml
